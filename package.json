{
  "name": "pink",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter='*' dev",
    "dev:backend": "bun --watch apps/backend/src/server.ts",
    "dev:frontend": "bun --cwd apps/frontend run dev",
    "build": "bun run --filter='*' build",
    "build:backend": "bun build apps/backend/src/server.ts --outdir dist/backend --target bun",
    "build:frontend": "bun --cwd apps/frontend run build",
    "test": "bun test",
    "test:backend": "bun --cwd apps/backend test",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules dist"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@elysiajs/swagger": "^1.3.1"
  }
}
